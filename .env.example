# ─── Supabase (REQUIRED) ───
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Next.js Frontend (Supabase public keys) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Backend ───
INTERNAL_BRIDGE_SECRET=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ─── AWS (optional — for SQS queue) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
AWS_SQS_QUEUE_URL=
BACKEND_URL=http://localhost:4000

# ─── OpenAI (optional — for CoPilot AI mode) ───
# OPENAI_API_KEY=sk-...

# Model provider API keys are now stored in the system_keys Supabase table.
# The following env vars are optional fallbacks (only used if no DB keys exist):
# ELEVENLABS_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY, HEDRA_API_KEY,
# ARK_API_KEY, KIE_AI_API_KEY, BYTEPLUS_ACCESS_KEY_ID, BYTEPLUS_SECRET_ACCESS_KEY
# ANTHROPIC_API_KEY
